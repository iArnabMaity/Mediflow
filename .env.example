# MediFlow Environment Configuration

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_AI_SERVICE_URL=http://localhost:8000

# Backend
NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://user:password@localhost:5432/mediflow
REDIS_URL=redis://localhost:6379
JWT_SECRET=your-secret-key-here
JWT_EXPIRE=24h

# AI Service
AI_SERVICE_PORT=8000
OLLAMA_URL=http://localhost:11434
HUGGINGFACE_API_KEY=
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=

# Database
POSTGRES_USER=mediflow_user
POSTGRES_PASSWORD=mediflow_password
POSTGRES_DB=mediflow
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Email (Optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Logging
LOG_LEVEL=info
SENTRY_DSN=

# Feature Flags
ENABLE_AI_RECOMMENDATIONS=true
ENABLE_TELEHEALTH=false
ENABLE_PRESCRIPTION_TRACKING=true
